@dp.message_handler(commands=['send'])
async def process_broadcast(message: types.Message):
    if message.from_user.id == ADMIN_ID:
        msg = message.text.replace("/send ", "")
        count = 0
        for user in subscribed_users:
            try:
                await bot.send_message(user, f"📢 **ANNUNCIATION:**\n\n{msg}")
                count += 1
            except: continue
        await message.answer(f"✅ {count} জন মেম্বারকে মেসেজ পাঠানো হয়েছে।")

