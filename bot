# ওটিপি নাম্বার নেওয়ার লজিক
@dp.callback_query_handler(text="get_number")
async def get_otp_number(call: types.CallbackQuery):
    if call.from_user.id not in subscribed_users:
        await call.answer("আগে সাবস্ক্রিপশন কিনুন!", show_alert=True)
        return
    
    keyboard = InlineKeyboardMarkup()
    keyboard.add(
        InlineKeyboardButton("Venezuela 🇻🇪", callback_data="country_ven"),
        InlineKeyboardButton("Cameroon 🇨🇲", callback_data="country_cam")
    )
    await call.message.answer("একটি দেশ সিলেক্ট করুন:", reply_markup=keyboard)
    await call.answer()

# সাবস্ক্রিপশন স্ট্যাটাস চেক
@dp.callback_query_handler(text="my_status")
async def check_status(call: types.CallbackQuery):
    status = "Active ✅" if call.from_user.id in subscribed_users else "Inactive ❌"
    await call.message.answer(f"আপনার সাবস্ক্রিপশন স্ট্যাটাস: {status}")
    await call.answer()

